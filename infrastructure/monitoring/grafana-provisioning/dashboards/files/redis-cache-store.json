  "panels": [
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 1,
      "title": "Redis server (redis_exporter, job=redis)",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "green", "value": 1 }
            ]
          },
          "unit": "none"
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 8, "x": 0, "y": 1 },
      "id": 2,
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "value_and_name"
      },
      "targets": [
        {
          "expr": "max(redis_up{job=\"redis\"}) or vector(0)",
          "legendFormat": "redis_up",
          "refId": "A"
        }
      ],
      "title": "redis_up (max)",
      "description": "0 when exporter cannot reach Redis or scrape is missing. Local docker-compose enables redis-exporter + this job.",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "unit": "none" },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 8, "x": 8, "y": 1 },
      "id": 3,
      "options": {
        "colorMode": "none",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "value_and_name"
      },
      "targets": [
        {
          "expr": "max(redis_connected_clients{job=\"redis\"})",
          "legendFormat": "clients",
          "refId": "A"
        }
      ],
      "title": "Connected clients (max)",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "max": 100,
          "min": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 80 },
              { "color": "red", "value": 95 }
            ]
          },
          "unit": "percent"
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 8, "x": 16, "y": 1 },
      "id": 4,
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "value_and_name"
      },
      "targets": [
        {
          "expr": "100 * (max(redis_memory_used_bytes{job=\"redis\"}) / clamp_min(max(redis_memory_max_bytes{job=\"redis\"}), 1))",
          "legendFormat": "memory %",
          "refId": "A"
        }
      ],
      "title": "Memory vs maxmemory (approx %)",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "unit": "percent", "min": 0, "max": 1 },
        "overrides": []
      },
      "gridPos": { "h": 7, "w": 12, "x": 0, "y": 5 },
      "id": 5,
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "expr": "100 * (redis_memory_used_bytes{job=\"redis\"} / clamp_min(redis_memory_max_bytes{job=\"redis\"}, 1))",
          "legendFormat": "{{instance}} used %",
          "refId": "A"
        }
      ],
      "title": "Memory usage (% of maxmemory)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "unit": "ops" },
        "overrides": []
      },
      "gridPos": { "h": 7, "w": 12, "x": 12, "y": 5 },
      "id": 6,
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "expr": "sum by (instance) (rate(redis_commands_processed_total{job=\"redis\"}[5m]))",
          "legendFormat": "{{instance}} cmd/s",
          "refId": "A"
        }
      ],
      "title": "Commands processed / sec",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "unit": "ops" },
        "overrides": []
      },
      "gridPos": { "h": 7, "w": 8, "x": 0, "y": 12 },
      "id": 7,
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "expr": "sum by (instance) (rate(redis_evicted_keys_total{job=\"redis\"}[5m]))",
          "legendFormat": "{{instance}} evicted/s",
          "refId": "A"
        },
        {
          "expr": "sum by (instance) (rate(redis_expired_keys_total{job=\"redis\"}[5m]))",
          "legendFormat": "{{instance}} expired/s",
          "refId": "B"
        }
      ],
      "title": "Evicted & expired keys / sec",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "unit": "none" },
        "overrides": []
      },
      "gridPos": { "h": 7, "w": 8, "x": 8, "y": 12 },
      "id": 8,
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "expr": "redis_blocked_clients{job=\"redis\"}",
          "legendFormat": "{{instance}} blocked",
          "refId": "A"
        }
      ],
      "title": "Blocked clients",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "unit": "percentunit", "min": 0, "max": 1 },
        "overrides": []
      },
      "gridPos": { "h": 7, "w": 8, "x": 16, "y": 12 },
      "id": 9,
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom", "showLegend": false },
        "tooltip": { "mode": "single", "sort": "none" }
      },
      "targets": [
        {
          "expr": "sum(rate(redis_keyspace_hits_total{job=\"redis\"}[5m])) / clamp_min(sum(rate(redis_keyspace_hits_total{job=\"redis\"}[5m])) + sum(rate(redis_keyspace_misses_total{job=\"redis\"}[5m])), 1e-12)",
          "legendFormat": "hit ratio",
          "refId": "A"
        }
      ],
      "title": "Keyspace hit ratio (global)",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 19 },
      "id": 10,
      "title": "App ↔ Redis (job=chatapp-api)",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "unit": "ops" },
        "overrides": []
      },
      "gridPos": { "h": 7, "w": 12, "x": 0, "y": 20 },
      "id": 11,
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "expr": "sum by (vm) (rate(redis_fanout_publish_failures_total{job=\"chatapp-api\"}[5m]))",
          "legendFormat": "{{vm}} failures/s",
          "refId": "A"
        }
      ],
      "title": "Realtime Redis publish failures / sec",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "unit": "ops" },
        "overrides": []
      },
      "gridPos": { "h": 7, "w": 12, "x": 12, "y": 20 },
      "id": 12,
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "expr": "sum by (result) (rate(message_channel_insert_lock_total{job=\"chatapp-api\"}[5m]))",
          "legendFormat": "lock {{result}}",
          "refId": "A"
        }
      ],
      "title": "POST /messages channel insert lock outcomes / sec",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "unit": "ops" },
        "overrides": []
      },
      "gridPos": { "h": 7, "w": 12, "x": 0, "y": 27 },
      "id": 13,
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "expr": "sum by (path, reason_detail) (rate(message_channel_insert_path_total{job=\"chatapp-api\",reason_detail=\"redis_set_error\"}[5m]))",
          "legendFormat": "{{path}} {{reason_detail}}",
          "refId": "A"
        }
      ],
      "title": "Insert path Redis acquire errors / sec",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "unit": "ops" },
        "overrides": []
      },
      "gridPos": { "h": 7, "w": 12, "x": 12, "y": 27 },
      "id": 14,
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "expr": "sum by (target, result) (rate(last_message_redis_update_total{job=\"chatapp-api\"}[5m]))",
          "legendFormat": "{{target}} {{result}}",
          "refId": "A"
        }
      ],
      "title": "Deferred last_message Redis writes / sec",
      "type": "timeseries"
    }
  ],
  "refresh": "30s",
  "schemaVersion": 39,
  "style": "dark",
  "tags": ["chatapp", "redis", "cache"],
  "templating": { "list": [] },
  "time": { "from": "now-6h", "to": "now" },
