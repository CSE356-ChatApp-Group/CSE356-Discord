# Realtime grading correctness baseline — mirrors prod.required.env exactly.
# Do not enable HTTP 503 shedding: autograder traffic spikes event-loop lag and
# clients surface JSON 503 as flaky sendMessage failures.
OVERLOAD_HTTP_SHED_ENABLED=false
OVERLOAD_LAG_SHED_MS=250
OVERLOAD_RSS_WARN_MB=320
OVERLOAD_RSS_HIGH_MB=420
OVERLOAD_RSS_CRITICAL_MB=520
OVERLOAD_LAG_WARN_MS=25
OVERLOAD_LAG_HIGH_MS=60
OVERLOAD_LAG_CRITICAL_MS=120
WS_AUTO_SUBSCRIBE_MODE=messages
READ_RECEIPT_DEFER_POOL_WAITING=0
CHANNEL_MESSAGE_USER_FANOUT=true
CHANNEL_MESSAGE_USER_FANOUT_MODE=recent_connect
CHANNEL_MESSAGE_USER_FANOUT_MAX=10000
MESSAGE_USER_FANOUT_HTTP_BLOCKING=false
USER_FEED_SHARD_COUNT=4
WS_RECENT_CONNECT_TTL_SECONDS=300
WS_RECENT_DISCONNECT_TTL_SECONDS=3600
PRESENCE_SWEEPER_MS=30000
PRESENCE_DB_CURSOR_TTL_SECS=600
WS_BOOTSTRAP_BATCH_SIZE=64
WS_BOOTSTRAP_CACHE_TTL_SECONDS=180
WS_APP_KEEPALIVE_INTERVAL_MS=10000
WS_MESSAGE_REPLAY_LIMIT=150
WS_MESSAGE_REPLAY_MAX_WINDOW_MS=3600000
WS_MESSAGE_REPLAY_STATEMENT_TIMEOUT_MS=1200
MESSAGE_POST_INSERT_STATEMENT_TIMEOUT_MS=5000
SEARCH_TRIGRAM_MIN_LEN_SCOPED=999
SEARCH_TRIGRAM_MIN_LEN_UNSCOPED=999
