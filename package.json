{
  "name": "chatapp-monorepo",
  "private": true,
  "workspaces": [
    "backend",
    "frontend"
  ],
  "scripts": {
    "typecheck": "npm --prefix backend run typecheck && npm --prefix frontend run typecheck",
    "test": "npm --prefix backend run test && npm --prefix frontend run test",
    "build": "npm --prefix backend run build && npm --prefix frontend run build",
    "monitoring:up": "./scripts/monitoring-up.sh",
    "monitoring:status": "./scripts/monitoring-status.sh",
    "monitoring:restart": "docker compose restart prometheus grafana alertmanager loki promtail tempo node-exporter && ./scripts/monitoring-status.sh",
    "monitoring:logs": "docker compose logs -f prometheus grafana alertmanager loki promtail tempo node-exporter",
    "monitoring:down": "docker compose stop prometheus grafana alertmanager loki promtail tempo node-exporter",
    "load:staging": "./scripts/run-staging-capacity.sh break",
    "load:staging:smoke": "./scripts/run-staging-capacity.sh smoke",
    "load:staging:quick": "./scripts/run-staging-capacity.sh quick",
    "load:staging:peak": "./scripts/run-staging-capacity.sh peak",
    "load:staging:break": "./scripts/run-staging-capacity.sh break",
    "load:staging:slo": "./scripts/run-staging-capacity.sh slo",
    "load:staging:tune": "./scripts/run-staging-capacity.sh tune",
    "load:staging:break-fast": "./scripts/run-staging-capacity.sh break-fast",
    "e2e:install": "npm --prefix frontend run e2e:install",
    "e2e": "npm --prefix frontend run e2e",
    "e2e:ci": "npm --prefix frontend run e2e:ci",
    "e2e:full": "npm --prefix frontend run e2e:full",
    "e2e:full:ci": "npm --prefix frontend run e2e:full:ci",
    "e2e:quick": "npm --prefix frontend run e2e:quick",
    "e2e:quick:ci": "npm --prefix frontend run e2e:quick:ci",
    "e2e:staging": "npm --prefix frontend run e2e:staging",
    "e2e:staging:ci": "npm --prefix frontend run e2e:staging:ci",
    "e2e:heavy": "npm --prefix frontend run e2e:heavy",
    "e2e:auth": "npm --prefix frontend run e2e:auth",
    "e2e:messaging": "npm --prefix frontend run e2e:messaging",
    "e2e:community": "npm --prefix frontend run e2e:community",
    "e2e:dm-invite": "npm --prefix frontend run e2e:dm-invite",
    "e2e:dm-realtime:root": "npm --prefix frontend run build && playwright test -c playwright.config.cjs e2e/dm-realtime-delivery.spec.ts",
    "api-contract": "npm --prefix backend run api-contract",
    "api-contract:local": "npm --prefix backend run api-contract:local"
  },
  "dependencies": {
    "@tanstack/react-virtual": "^3.13.23"
  }
}
