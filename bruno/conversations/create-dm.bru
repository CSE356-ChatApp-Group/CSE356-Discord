meta {
  name: Create or Get DM Conversation
  type: http
  seq: 1
}

post {
  url: {{baseUrl}}/conversations
  body: json
  auth: bearer
}

auth:bearer {
  token: {{accessToken}}
}

body:json {
  {
    "participantIds": ["PASTE_OTHER_USER_ID_HERE"]
  }
}

script:post-response {
  if (res.status === 201 || res.status === 200) {
    bru.setEnvVar("conversationId", res.body.conversation.id);
    console.log("✅ Conversation:", res.body.conversation.id, res.body.created ? "(new)" : "(existing)");
  }
}
