# =============================================================================
# ChatApp – environment variables
# Copy to .env and fill in values.  Never commit .env to version control.
# Full reference and production shared-.env audit checklist: docs/env.md
# =============================================================================

# ── API ───────────────────────────────────────────────────────────────────────
NODE_ENV=development
AUTH_BYPASS=true
PORT=3000
LOG_LEVEL=info
# Production: logs one JSON capacity_snapshot line every 60s (grep "capacity_snapshot").
# Override interval (ms) or set to 0 to disable. /health?diagnostic=1 returns the same shape.
# CAPACITY_SNAPSHOT_INTERVAL_MS=60000

# ── Security ──────────────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_ACCESS_SECRET=CHANGE_ME
JWT_REFRESH_SECRET=CHANGE_ME_REFRESH
# Optional JWT tuning: JWT_ACCESS_TTL, JWT_REFRESH_TTL, JWT_ACCESS_VERIFY_CACHE_TTL_MS,
# JWT_DENYLIST_CHECK_CACHE_TTL_MS, JWT_TOKEN_CACHE_MAX_ENTRIES
# Optional OAuth token signing: OAUTH_PENDING_SECRET, OAUTH_LINK_SECRET

# ── Database ──────────────────────────────────────────────────────────────────
POSTGRES_PASSWORD=chatapp_dev
DATABASE_URL=postgres://chatapp:chatapp_dev@localhost:5432/chatapp
# Production: when DATABASE_URL targets PgBouncer (…:6432), deploy-prod requires a direct URL for
# pg_dump (transaction pool breaks COPY). Add to /opt/chatapp/shared/.env on the app VM, same creds/host:5432:
# PGDUMP_DATABASE_URL=postgres://chatapp:SECRET@10.0.1.62:5432/chatapp_prod
# Max Postgres connections per Node.js process to PgBouncer. Overrides are optional:
# deploy-staging.sh / deploy-prod.sh compute PG_POOL_MAX, POOL_CIRCUIT_BREAKER_QUEUE,
# BCRYPT_MAX_CONCURRENT, FANOUT_QUEUE_CONCURRENCY, and Postgres max_connections from
# the target VM's vCPU/RAM on every deploy.
# PG_POOL_MAX=50
# POOL_CIRCUIT_BREAKER_QUEUE=32
# BCRYPT_MAX_CONCURRENT=8
# BCRYPT_MAX_WAITERS=200
# BCRYPT_QUEUE_WAIT_TIMEOUT_MS=2000
# BCRYPT_ROUNDS=

# Overload: optional early 503 when event-loop p99 lag exceeds OVERLOAD_LAG_SHED_MS.
# Default is off so requests queue on the Node event loop instead of failing fast.
# deploy-prod.sh sets OVERLOAD_HTTP_SHED_ENABLED=false on the server; do not copy staging=true blindly.
# OVERLOAD_HTTP_SHED_ENABLED=true
# OVERLOAD_LAG_SHED_MS=300
# RSS / lag stage thresholds (optional): OVERLOAD_RSS_WARN_MB, OVERLOAD_RSS_HIGH_MB,
# OVERLOAD_RSS_CRITICAL_MB, OVERLOAD_LAG_WARN_MS, OVERLOAD_LAG_HIGH_MS, OVERLOAD_LAG_CRITICAL_MS
# Testing only: FORCE_OVERLOAD_STAGE=0..3

# ── Auth rate limits (optional; Redis-backed; key = IP + username/email) ─────
# Code defaults: register 20 / 10 min, login 60 / 1 min, oauth-connect 30 / 5 min.
# Local docker compose raises register/login to 500 for parallel E2E only — not for prod.
# AUTH_REGISTER_RATE_LIMIT_MAX=20
# AUTH_REGISTER_RATE_LIMIT_WINDOW_MS=600000
# AUTH_LOGIN_RATE_LIMIT_MAX=60
# AUTH_LOGIN_RATE_LIMIT_WINDOW_MS=60000
# AUTH_CONNECT_RATE_LIMIT_MAX=30
# AUTH_CONNECT_RATE_LIMIT_WINDOW_MS=300000
# Remove all auth rate limits (login, register, oauth-connect). Reasonable on isolated
# grading/autograder VMs; avoid on public-facing production if you care about abuse.
# DISABLE_RATE_LIMITS=true

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_PASSWORD=redis_dev
REDIS_URL=redis://:redis_dev@localhost:6379
# Realtime fanout: retries per channel publish on transient Redis errors (1–8, default 4).
# REDIS_FANOUT_PUBLISH_MAX_ATTEMPTS=4
# POST /messages idempotency (dedupe keys in Redis). When Redis is down, dedupe is skipped (fail open).
# MSG_IDEM_PENDING_TTL_SECS=120
# MSG_IDEM_SUCCESS_TTL_SECS=86400

# ── Search ────────────────────────────────────────────────────────────────────
# Search uses PostgreSQL native FTS (tsvector + websearch_to_tsquery).
# No external search service required.

# ── Object storage (MinIO local / S3 cloud) ───────────────────────────────────
S3_BUCKET=chatapp-attachments
S3_REGION=us-east-1
# URL browsers/tests use for PUT/GET (must match presign Host). Use the mapped port if MinIO is not on 9000.
S3_ENDPOINT=http://127.0.0.1:9000       # remove for real AWS S3
# Optional: Docker/internal URL for DeleteObjects only (e.g. http://minio:9000). When S3_ENDPOINT has
# no path, presigning always uses S3_ENDPOINT so a mismatched port (e.g. :9000 vs :19009) cannot break SigV4.
# S3_INTERNAL_ENDPOINT=
# Presign signing host if browser URL and SigV4 host must differ: S3_PRESIGN_SIGNING_ENDPOINT=
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin

# ── Advanced API tunables (see docs/env.md) ───────────────────────────────────
# Messages / fanout: FANOUT_QUEUE_CONCURRENCY, FANOUT_CRITICAL_MAX_DEPTH
# HTTP caches: COMMUNITIES_LIST_CACHE_TTL_SECS, CHANNELS_LIST_CACHE_TTL_SECS
# Presence: PRESENCE_FANOUT_CACHE_TTL_SECONDS
# WebSocket: WS_BACKPRESSURE_DROP_BYTES, WS_BACKPRESSURE_KILL_BYTES, WS_ACL_CACHE_MAX_ENTRIES,
#   WS_BOOTSTRAP_BATCH_SIZE (default 96 parallel Redis subscribes per batch), WS_BOOTSTRAP_CACHE_TTL_SECONDS
# Channel fanout: CHANNEL_MESSAGE_USER_FANOUT defaults ON — duplicates message:created to user:<id>
#   for each channel-visible member (set CHANNEL_MESSAGE_USER_FANOUT=0 to disable on tiny hosts).
#   CHANNEL_MESSAGE_USER_FANOUT_MAX caps recipients (default 5000, max 10000).
# Observability: OTEL_ENABLED, OTEL_TRACES_SAMPLE_RATIO, OTEL_EXPORTER_OTLP_ENDPOINT, LOG_SERVICE_NAME
# Startup: STARTUP_DEPENDENCY_MAX_WAIT_MS

# ── OAuth (optional) ──────────────────────────────────────────────────────────
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GOOGLE_CALLBACK_URL=http://localhost:3000/api/v1/auth/google/callback

# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=
# GITHUB_CALLBACK_URL=http://localhost:3000/api/v1/auth/github/callback

# Course OAuth2 / OIDC provider (CSE356)
# Uses OpenID Connect discovery against realm oauth.
# COURSE_OIDC_DISCOVERY_URL=https://infra-auth.cse356.compas.cs.stonybrook.edu/realms/oauth/.well-known/openid-configuration
# COURSE_OIDC_CLIENT_ID=web-service
# COURSE_OIDC_CLIENT_SECRET=web-service-secret
# COURSE_OIDC_CALLBACK_URL=http://localhost:3000/api/v1/auth/course/callback

# ── Frontend ──────────────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:5173
CORS_ORIGIN=http://localhost:5173
VITE_API_BASE=http://localhost/api/v1
VITE_WS_BASE=ws://localhost/ws

# ── Monitoring ────────────────────────────────────────────────────────────────
GRAFANA_PASSWORD=admin
ALERT_ENVIRONMENT=local
# Optional personal test channel for local experiments.
DISCORD_WEBHOOK_URL_LOCAL=
# Use these on the staging and production hosts.
DISCORD_WEBHOOK_URL_STAGING=
DISCORD_WEBHOOK_URL_PROD=
# Optional generic fallback if you want one webhook for all environments.
DISCORD_WEBHOOK_URL=

# ── MinIO console ─────────────────────────────────────────────────────────────
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
