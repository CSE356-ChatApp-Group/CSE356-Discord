meta {
  name: Register
  type: http
  seq: 1
}

post {
  url: {{baseUrl}}/auth/register
  body: json
  auth: none
}

body:json {
  {
    "email": "dev@example.com",
    "username": "devuser",
    "password": "Password1!",
    "displayName": "Dev User"
  }
}

script:post-response {
  if (res.status === 201) {
    bru.setEnvVar("accessToken", res.body.accessToken);
    bru.setEnvVar("userId", res.body.user.id);
    console.log("✅ Registered. Token saved.");
  }
}
