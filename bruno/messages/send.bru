meta {
  name: Send Message
  type: http
  seq: 1
}

post {
  url: {{baseUrl}}/messages
  body: json
  auth: bearer
}

auth:bearer {
  token: {{accessToken}}
}

body:json {
  {
    "channelId": "{{channelId}}",
    "content": "Hello, world! 👋"
  }
}

script:post-response {
  if (res.status === 201) {
    bru.setEnvVar("messageId", res.body.message.id);
    console.log("✅ Message sent:", res.body.message.id);
  }
}
