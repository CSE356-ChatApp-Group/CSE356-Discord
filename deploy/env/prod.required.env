# Realtime grading correctness baseline.
# Keep Redis-backed auth rate limits enabled on public-facing prod (deploy scripts tee
# DISABLE_RATE_LIMITS=true first; this row wins on merge).
# Node.js libuv thread pool: app VMs are 8 vCPU; default of 4 limits bcrypt concurrency
# to min(4, cpu_count+2)=4, causing queue buildup under burst registrations.
UV_THREADPOOL_SIZE=8
DISABLE_RATE_LIMITS=false
AUTO_IP_BAN_ENABLED=true
COMMUNITY_JOIN_PER_IP_WINDOW_MS=60000
COMMUNITY_JOIN_PER_IP_MAX=300
COMMUNITY_JOIN_PER_USER_WINDOW_MS=60000
COMMUNITY_JOIN_PER_USER_MAX=120
OVERLOAD_HTTP_SHED_ENABLED=false
OVERLOAD_LAG_SHED_MS=250
WS_PROFILE=generated-client
WS_AUTO_SUBSCRIBE_MODE=messages
REALTIME_EVENT_ALIAS_FANOUT=false
READ_RECEIPT_DEFER_POOL_WAITING=0
CHANNEL_MESSAGE_USER_FANOUT=true
# Keep logical user duplicates focused on reconnect bridge recipients.
CHANNEL_MESSAGE_USER_FANOUT_MODE=recent_connect
CHANNEL_MESSAGE_RECENT_CONNECT_INCLUDE_CONNECTED_FALLBACK=false
CHANNEL_MESSAGE_USER_FANOUT_MAX=10000
CHANNEL_MESSAGE_RECENT_CONNECT_FALLBACK_PROBE_MAX=512
RECENT_CONNECT_TARGET_CACHE_MS=250
# Await all logical user-feed publishes when sync fanout is enabled. The default
# POST path now accepts after DB commit + async enqueue to protect hot sends.
MESSAGE_USER_FANOUT_HTTP_BLOCKING=true
MESSAGE_POST_IMMEDIATE_RECENT_BRIDGE_ENABLED=false
# recent_bridge remains bounded for short canaries that explicitly re-enable it.
MESSAGE_POST_RECENT_BRIDGE_TIMEOUT_MS=500
MESSAGE_POST_FAST_ACCEPT_ENABLED=true
MESSAGE_POST_AWAIT_CACHE_BUST=false
# Shorter window shrinks channel:recent_connect zset cardinality / churn (still covers grader WS gaps).
WS_RECENT_CONNECT_TTL_SECONDS=300
# Keeps the narrow userfeed bridge alive for sockets that gain channel access
# after connect until the server confirms channel:<id> subscription.
CHANNEL_BOOTSTRAP_PENDING_TTL_SECONDS=300
PRESENCE_SWEEPER_MS=30000
WS_BOOTSTRAP_PROGRESSIVE_READY=true
WS_BOOTSTRAP_BATCH_SIZE=128
WS_BOOTSTRAP_CACHE_TTL_SECONDS=180
# Delay Redis channel/conversation UNSUBSCRIBE after local refcount reaches zero
# to reduce subscribe/unsubscribe churn during rapid reconnect/bootstrap cycles.
# Set to 0 to restore immediate unsubscribe behavior.
WS_REDIS_SUBSCRIPTION_RELEASE_GRACE_MS=30000
WS_APP_KEEPALIVE_INTERVAL_MS=8000
# Wider than default 20s: under burst load a delayed event loop can miss one pong
# tick and trigger heartbeat_timeout (1006); 30s reduces premature server-side closes.
WS_HEARTBEAT_INTERVAL_MS=30000
# Kill immediately on first missed ping (no grace period). The 2-miss grace period
# keeps zombie connections alive too long, triggering expensive stale-map recovery
# when messages can't reach unresponsive clients. Immediate kill keeps subscriber
# maps clean, reducing fallback recovery overhead.
WS_HEARTBEAT_MISSED_PINGS_BEFORE_KILL=1
WS_REPLAY_SEMAPHORE_MAX=6
WS_REPLAY_DB_MAX_IN_FLIGHT=4
WS_REPLAY_POOL_WAITING_THRESHOLD=2
WS_REPLAY_DEFER_MAX_ATTEMPTS=8
WS_REPLAY_DEFER_BASE_DELAY_MS=250
WS_REPLAY_DEFER_MAX_DELAY_MS=4000
WS_REPLAY_USER_COOLDOWN_MS=3000
WS_MESSAGE_REPLAY_LIMIT=100
WS_MESSAGE_REPLAY_MAX_WINDOW_MS=600000
WS_REPLAY_SKIP_DB_WHEN_PENDING_HIT=true
# Bound pending replay ZSET cardinality (code default 400). Lower = less RAM per hot user under fanout.
WS_REPLAY_PENDING_USER_MAX_ZSET=400
# Async POST fanout dedupe key TTL seconds (code default 7200). Shorter recycles fanout:v1:done:* faster under load.
MESSAGE_FANOUT_JOB_DONE_TTL_SEC=3600
# Pending replay: avoid Redis mailboxes for long-offline channel/DM members (DB replay still correct).
WS_REPLAY_PENDING_ONLY_ACTIVE=true
WS_REPLAY_RECENT_USER_WINDOW_SECONDS=60
# Unified pending eligibility is rolled out; keep global legacy marker probe off to avoid Redis amplification.
WS_PENDING_ELIGIBLE_LEGACY_FALLBACK=false
# When legacy is false: second EXISTS (recent/replay markers) only for callers without recentTargets (DM); channel keeps single-phase.
WS_PENDING_ELIGIBLE_CONVERSATION_MARKER_FALLBACK=true
WS_HOT_LOG_SAMPLE_RATE=0
REDIS_FANOUT_RETRY_INFO_SAMPLE_RATE=0
# Runtime log controls: keep enabled for emergency on/off without restart.
# No logctl:* keys are set by default, so existing env behavior remains unchanged.
RUNTIME_LOG_CONTROL_ENABLED=true
RUNTIME_LOG_CONTROL_KEY_PREFIX=logctl
RUNTIME_LOG_CONTROL_REFRESH_MS=5000
# Keep low-noise baseline visibility for POST /messages latency breakdowns.
MESSAGE_POST_E2E_TRACE_MIN_MS=1500
MESSAGE_POST_E2E_TRACE_SAMPLE_RATE=0.005
# Cheap read-receipt wins: coalesce short duplicate bursts from reconnecting/mobile clients.
# This does not drop higher cursors; it skips only duplicate/no-advance hot-path work.
READ_RECEIPT_SAME_MESSAGE_COALESCE_MS=600
READ_RECEIPT_SCOPE_CURSOR_CACHE_TTL_MS=800
READ_RECEIPT_SCOPE_DEBOUNCE_MS=1200
READ_RECEIPT_FANOUT_ENABLED=true
READ_RECEIPT_FULL_DEFER_ON_WS_PRESSURE_ENABLED=true
# WS_REPLAY_PENDING_LEGACY_ALL=true
# Meilisearch: active. Fallback to Postgres FTS on zero candidates (e.g. unbackfilled messages).
MEILI_ENABLED=true
SEARCH_BACKEND=meili
SEARCH_USE_READ_REPLICA=true
MEILI_HOST=http://10.0.0.146:7700
MEILI_INDEX_MESSAGES=messages
MEILI_CANDIDATE_LIMIT=500
MEILI_TIMEOUT_MS=1200
# Freshness disabled: 0% cache hit rate + 85.8% fallback rate made every freshness
# query wasted replica I/O. Re-enable once merge cycles stabilize below 5 min.
MEILI_FRESHNESS_WINDOW_MS=0
MEILI_FRESHNESS_CANDIDATE_LIMIT=100
MEILI_WRITE_FLUSH_MS=10000
# Larger batches: fewer, bigger Meili write tasks → fewer merge cycles → more search headroom.
MEILI_WRITE_BATCH_SIZE=500
# Cross-worker write queue: app workers enqueue message index mutations to Redis,
# while a leased consumer drains larger batches into Meilisearch.
MEILI_WRITE_STREAM_ENABLED=true
MEILI_WRITE_STREAM_CONSUMER_ENABLED=true
# Single consumer slot: two slots doubled task-submission rate and drove 17m+ merge cycles.
MEILI_WRITE_STREAM_CONSUMER_SLOTS=1
MEILI_WRITE_STREAM_READ_COUNT=1000
MEILI_WRITE_STREAM_BLOCK_MS=1000
MEILI_WRITE_STREAM_COALESCE_MS=5000
# POST /messages: cross-worker Redis lease wait before giving 503 (hot channels).
# Emergency/default prod stance: bypass the per-channel Redis insert mutex.
# The mutex serializes hot-channel sends and was the active 503 bottleneck under burst.
MESSAGE_INSERT_LOCK_MODE=optimistic
MESSAGE_INSERT_LOCK_WAIT_TIMEOUT_MS=4000
MESSAGE_INSERT_LOCK_REDIS_OP_TIMEOUT_MS=600
MESSAGE_INSERT_LOCK_RECENT_TIMEOUT_WINDOW_MS=4000
MESSAGE_INSERT_LOCK_RECENT_TIMEOUT_BACKOFF_MIN_MS=200
MESSAGE_INSERT_LOCK_RECENT_TIMEOUT_BACKOFF_MAX_MS=500
# Structured info log `message_channel_insert_path` (high volume). Metrics always emit.
# When MESSAGE_INSERT_LOCK_PATH_LOG=true, sample rate is forced to 1.0 — use only for short debugging.
MESSAGE_INSERT_LOCK_PATH_LOG=false
MESSAGE_INSERT_LOCK_PATH_LOG_SAMPLE_RATE=0
SEARCH_DEFER_ON_INSERT_LOCK_PRESSURE=false
USER_FEED_SHARD_COUNT=64
COMMUNITY_FEED_SHARD_COUNT=64
CHANNEL_MESSAGE_SKIP_USERFEED_PUBLISH=true
# POST /messages: wall budget for message-list cache bust only (legacy env name; not fanout PUBLISH).
# Keep async post-message fanout enabled. Sync await was the dominant source of
# POST /messages p95/p99 spikes (multi-second fanout_wall_ms in e2e traces).
# Reliability remains covered by direct channel subscriptions, deferred
# dedup/retry fanout jobs, pending replay, and websocket replay.
MESSAGE_POST_SYNC_FANOUT=false
POST_INSERT_REDIS_WORK_TIMEOUT_MS=750
# Presence is Redis-first under load; snapshots are async analytics/write-behind.
PRESENCE_DB_MIRROR_MODE=async
PRESENCE_DB_MIRROR_FLUSH_INTERVAL_MS=1000
PRESENCE_DB_MIRROR_BATCH_SIZE=250
PRESENCE_FANOUT_RECIPIENT_LOOKUP_MODE=self
# Slow non-message HTTP trace (warn log slow_http_request_trace; correlate with pg_stat_statements).
# After a diagnostic window, raise MIN_MS or remove these lines to avoid sustained high-volume warn logs.
SLOW_HTTP_TRACE_MIN_MS=2500
SLOW_HTTP_TRACE_EXCLUDE_PREFIXES=/api/v1/messages,/health,/metrics
# When PG_READ_REPLICA_URL is set (merged env), SELECTs use the replica; TCP/replica-down errors fall back to primary unless PG_READ_FALLBACK_TO_PRIMARY=false.
PG_READ_FALLBACK_TO_PRIMARY=true
# Bound replica reads so a wedged/slow standby fails over to primary instead of holding grader requests for seconds.
PG_READ_QUERY_TIMEOUT_MS=750
# GET /unread-counts pressure controls:
# - shed before DB when primary pool queue is already building
# - cap concurrent unread DB work per worker
UNREAD_COUNTS_DEFER_POOL_WAITING=8
UNREAD_COUNTS_MAX_INFLIGHT=48
# Keep route-level read timeout bounded; timeout path returns 200 empty payload.
UNREAD_COUNTS_QUERY_TIMEOUT_MS=750
OTEL_ENABLED=true
OTEL_TRACES_SAMPLE_RATIO=0.005
OTEL_EXPORTER_OTLP_ENDPOINT="http://10.0.1.102:4318/v1/traces"
# Last-message: POST path writes Redis keys `ch:last_msg:*` / `conv:last_msg:*` first. When false,
# background PG flush of `channels.last_message_*` / `conversations.last_message_*` is skipped (lower DB UPDATE volume).
# List routes merge Redis overlay; DB columns may lag. Set true only when operators need fresh DB rows without Redis (see docs/env.md).
LAST_MESSAGE_PG_RECONCILE_ENABLED=false
CONVERSATION_LAST_MESSAGE_PG_RECONCILE_ENABLED=false
