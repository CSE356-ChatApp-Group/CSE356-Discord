{
  "name": "chatapp-monorepo",
  "private": true,
  "workspaces": [
    "backend",
    "frontend"
  ],
  "scripts": {
    "typecheck": "npm run typecheck --workspace=backend --workspace=frontend",
    "test": "npm run test --workspace=backend && npm run test --workspace=frontend",
    "build": "npm run build --workspace=backend && npm run build --workspace=frontend",
    "monitoring:up": "./scripts/monitoring-up.sh",
    "monitoring:status": "./scripts/monitoring-status.sh",
    "monitoring:restart": "docker compose restart prometheus grafana alertmanager loki promtail tempo node-exporter && ./scripts/monitoring-status.sh",
    "monitoring:logs": "docker compose logs -f prometheus grafana alertmanager loki promtail tempo node-exporter",
    "monitoring:down": "docker compose stop prometheus grafana alertmanager loki promtail tempo node-exporter",
    "load:staging": "./scripts/run-staging-capacity.sh break",
    "load:staging:smoke": "./scripts/run-staging-capacity.sh smoke",
    "load:staging:quick": "./scripts/run-staging-capacity.sh quick",
    "load:staging:peak": "./scripts/run-staging-capacity.sh peak",
    "load:staging:break": "./scripts/run-staging-capacity.sh break",
    "load:staging:slo": "./scripts/run-staging-capacity.sh slo",
    "load:staging:tune": "./scripts/run-staging-capacity.sh tune",
    "load:staging:break-fast": "./scripts/run-staging-capacity.sh break-fast",
    "e2e:install": "npm run e2e:install --workspace=frontend",
    "e2e": "npm run e2e --workspace=frontend",
    "e2e:ci": "npm run e2e:ci --workspace=frontend",
    "e2e:full": "npm run e2e:full --workspace=frontend",
    "e2e:full:ci": "npm run e2e:full:ci --workspace=frontend",
    "e2e:staging": "npm run e2e:staging --workspace=frontend",
    "e2e:staging:ci": "npm run e2e:staging:ci --workspace=frontend",
    "e2e:heavy": "npm run e2e:heavy --workspace=frontend",
    "e2e:auth": "npm run e2e:auth --workspace=frontend",
    "e2e:messaging": "npm run e2e:messaging --workspace=frontend",
    "e2e:community": "npm run e2e:community --workspace=frontend",
    "e2e:dm-invite": "npm run e2e:dm-invite --workspace=frontend",
    "api-contract": "npm run api-contract --workspace=backend"
  }
}
